# Sample application-dev.properties file for SkyScope project
# This file shows the structure and required properties for the application.
# Copy this file to application-dev.properties and fill in the actual values.

# API Keys - Optional: These properties can be completely removed.
# If missing, the app will use JSON data from files instead.
# If you want to use real APIs, fill in the actual values (not placeholders).

geo_names_key=http://api.geonames.org/searchJSON?q={city_name}&maxRows=1&username=YOUR_GEONAMES_USERNAME
opensky_baseurl=https://opensky-network.org/api/states/all
amadeus_client_id=YOUR_AMADEUS_CLIENT_ID
amadeus_client_secret=YOUR_AMADEUS_CLIENT_SECRET
amadeus_auth_url=https://test.api.amadeus.com/v1/security/oauth2/token
amadeus_token_expiry=1700000
amadeus_city_search_api=https://test.api.amadeus.com/v1/reference-data/locations?keyword={keyword}&subType={subType}
amadeus_flight_offer_search_api=https://test.api.amadeus.com/v2/shopping/flight-offers
amadeus_cheapest_date_search=https://test.api.amadeus.com/v1/shopping/flight-dates
amadeus_final_price=https://test.api.amadeus.com/v1/shopping/flight-offers/pricing
amadeus_test_client_id=YOUR_AMADEUS_TEST_CLIENT_ID
amadeus_test_client_secret=YOUR_AMADEUS_TEST_CLIENT_SECRET
amadeus_test_auth_url=https://test.api.amadeus.com/v1/security/oauth2/token
amadeus_create_order=https://test.api.amadeus.com/v1/booking/flight-orders
amadeus_airline_code=https://test.api.amadeus.com/v1/reference-data/airlines?airlineCodes={airlineCodes}
